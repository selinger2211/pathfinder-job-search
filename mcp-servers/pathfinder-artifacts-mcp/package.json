{
  "name": "pathfinder-artifacts-mcp",
  "version": "1.0.0",
  "description": "Artifacts MCP Server for Pathfinder — centralized file storage for senior PM job search",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "bridge": "tsx src/bridge-standalone.ts",
    "bridge:dev": "tsx watch src/bridge-standalone.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
